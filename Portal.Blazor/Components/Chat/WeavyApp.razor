@implements IDisposable

<div @ref="_weavyContainer" class="weavy-app"></div>

@code{ 
    ElementReference _weavyContainer;

    [CascadingParameter]
    protected WeavyService Weavy { get; set; }

    [Parameter]
    public string SpaceKey { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IDictionary<string, object> Options { get; set; }

    public SpaceReference Space;
    public AppReference App;

    protected override async Task OnAfterRenderAsync(bool firstRender) {
        if (firstRender)
        {
            try
            {
                var options = new Dictionary<string, object>(Options);
                options["container"] = _weavyContainer;
                Space = await Weavy.Space(new { key = SpaceKey });
                App = await Space.App(options);
                await App.Open();
                StateHasChanged();
            }
            catch (Exception)
            {
                // Weavy chat is not available in this environment — silently skip
            }
        }
    }

    public void Dispose () {
        App?.Remove();
    }
}

