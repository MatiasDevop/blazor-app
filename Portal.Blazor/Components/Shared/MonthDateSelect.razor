@using System.Globalization
@using System.Linq.Expressions
<div class="month-date-select row">
    <Validations>
        <Validation Validator="ValidationRule.None" Status="_valid">
            <div class="col-6">
                <Select TValue="int" @bind-SelectedValue="Month" Disabled="Disabled">
                    <SelectItem TValue="int" Value="@(-1)" Hidden>Month</SelectItem>
                    @foreach (var i in Enumerable.Range(1, 12))
                    {
                        <SelectItem Value="i">@CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(i)</SelectItem>
                    }
                </Select>
            </div>
            <div class="col-6">
                <Select @bind-SelectedValue="Year" Disabled="Disabled">
                    <SelectItem TValue="int" Value="-1" Hidden>Year</SelectItem>
                    @foreach (var i in Enumerable.Range(0, 100))
                    {
                        <SelectItem Value="CurrentYear - i">@(CurrentYear - i)</SelectItem>
                    }
                </Select>
            </div>
        </Validation>
    </Validations>
    @if (ParentValidation != null)
    {
        <div class="col-12">
            <DateEdit Class="d-none" Date="Value">
                <Feedback>
                    <ValidationError/>
                </Feedback>
            </DateEdit>
        </div>
    }
</div>

@code {
    private static readonly int CurrentYear = DateTime.Now.AddYears(10).Year; //added 10 years ahead
    private int _month = -1;
    private int _year = -1;
    private bool _validating = false;
    private DateTime _value;
    private ValidationStatus _valid = ValidationStatus.None;

    private int Month
    {
        get => _month;
        set
        {
            _month = value;
            TryChangeValue();
        }
    }

    private int Year
    {
        get => _year;
        set
        {
            _year = value;
            TryChangeValue();
        }
    }

    protected override void OnInitialized()
    {
        if (ParentValidation == null) return;
        ParentValidation.ValidationStatusChanged += (_, args) =>
        {
            _valid = args.Status;
            StateHasChanged();
        };
    }

    public void Reset()
    {
        _month = -1;
        _year = -1;
        _valid = ValidationStatus.None;
    }

    private async void TryChangeValue()
    {
        if (!ValueChanged.HasDelegate)
            return;
        if (_month != -1 && _year != -1)
        {
            var date = DateTime.SpecifyKind(new DateTime(_year, _month, 1), DateTimeKind.Utc);
            await ValueChanged.InvokeAsync(date);
            await ParentValidation?.ValidateAsync(date);
        }
    }

    [Parameter]
    public DateTime Value
    {
        get => _value;
        set
        {
            if (_value == value)
                return;

            _value = value;
            if (value == DateTime.MinValue || value == DateTime.MaxValue)
            {
                _month = -1;
                _year = -1;
            }
            else
            {
                _month = value.Month;
                _year = value.Year;
            }
            if (ParentValidation != null)
                _valid = ParentValidation.Validate(_value);
        }
    }

    [Parameter]
    public EventCallback<DateTime> ValueChanged { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [CascadingParameter]
    public Validation ParentValidation { get; set; }

}

