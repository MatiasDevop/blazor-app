@using Blazorise.Icons.FontAwesome
@inject AuthStateService AuthStateService

<div class="navbar-landing">
    <div class="container d-flex d-sm-none justify-content-between">
        <img src="images/logo.svg" alt="logo" id="logo"/>
        <Blazorise.Icon Class="pointer" @onclick="() => _collapsed = !_collapsed" Name="FontAwesomeIcons.Bars" IconSize="IconSize.x2" TextColor="TextColor.White"/>
    </div>
    <div class="container d-flex">
        <div class="flex-sm-grow-1"></div>
        <div class="d-flex flex-2 justify-content-between justify-content-sm-center">
            <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">Students</NavLink>
            <div class="pipe"></div>
            <NavLink class="nav-link" href="employee">Employees</NavLink>
            <div class="pipe"></div>
            <NavLink class="nav-link" href="career-center">Career Center</NavLink>
            <div class="pipe"></div>
            <NavLink class="nav-link" href="company">Company</NavLink>
        </div>
        <div class="d-none d-sm-flex flex-1 justify-content-end">
            @if (_isAuthenticated)
            {
                <UserDropdown/>
            }
            else
            {
                <NavLink class="nav-link" href="dashboard"><i class="fas fa-user mr-1"></i> Login</NavLink>
                <div class="pipe"></div>
                <NavLink class="nav-link" href="sign-up"><i class="fas fa-edit mr-1"></i> Sign Up</NavLink>
            }
        </div>
    </div>
</div>
<MobileSidebar Collapsed="_collapsed"/>

@code {
    private bool _isAuthenticated = false;
    private bool _collapsed = true;

    protected override void OnInitialized()
    {
        AuthStateService.Authenticated.Subscribe(val =>
        {
            _isAuthenticated = val;
            StateHasChanged();
        });
    }

}

