@inject NavigationManager NavigationManager
<div class="cpcc-modal">
    <h3 class="section-header mt-2">Application Sent</h3>
    <h5 class="my-5 ml-2">We've sent your application to the employer for review, and they will contact you after they have had the chance to review it.</h5>
    <div class="row">
        <div class="d-flex flex-row-reverse mb-2" style="width: 100%;">
            <Button Color="Color.Primary" Size="global::Blazorise.Size.Large" class="px-4 py-1" @onclick="@OnOk">OK</Button>
        </div>
    </div>
</div>

@code {

    [CascadingParameter]
    public BlazoredModalInstance ModalInstance { get; set; }
    
    private async Task OnOk()
    {
        await ModalInstance.CloseAsync();
        NavigationManager.NavigateTo("/dashboard");
    }

}

