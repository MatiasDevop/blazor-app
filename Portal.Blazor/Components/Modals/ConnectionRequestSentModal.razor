@using ViewModels.Dtos
@inject WeavyService WeavyService
@inject UserProfileService UserProfileService
@inject IHttpClientFactory HttpClientFactory
@inject NavigationManager NavigationManager
<div class="cpcc-modal">
    <h3 class="section-header">Connection Request Sent</h3>
    <div class="mt-3 ml-2">Now you can...</div>
    <div class="row">
        <div class="col-12 col-lg-6 col-xl">
            <button class="btn btn-light connection-modal-option" @onclick="OnWave">
                <img src="images/high_five.svg"/>
                <h5>Wave Hello</h5>
            </button>
        </div>
        <div class="col-12 col-lg-6 col-xl">
            <button class="btn btn-light connection-modal-option" @onclick="OnSendProfile">
                <img src="images/share_profile.svg"/>
                <h5>Share My Profile</h5>
            </button>
        </div>
        <div class="col-12 col-lg-6 col-xl">
            <button class="btn btn-light connection-modal-option" @onclick="OnMessage">
                <img src="images/chat.svg"/>
                <h5>Start a Chat</h5>
            </button>
        </div>
        @if (ShowForwardResume)
        {
            <div class="col-12 col-lg-6 col-xl">
                <button class="btn btn-light connection-modal-option" @onclick="OnForwardResume">
                    <img src="images/forward_resume.svg"/>
                    <h5>Forward My Resume</h5>
                </button>
            </div>
        }
    </div>
</div>

@code {

    [CascadingParameter]
    public BlazoredModalInstance ModalInstance { get; set; }

    [Parameter]
    public Guid UserId { get; set; }

    [Parameter]
    public bool ShowForwardResume { get; set; }
    
    private Guid _activeProfileId;

    protected override void OnInitialized()
    {
        UserProfileService.Profile.Subscribe(activeProfile =>
        {
            _activeProfileId = activeProfile.Id;
        });
    }

    private async void OnWave()
    {
        await WeavyService.SendMessage(UserId, "??");
        await ModalInstance.CloseAsync();
    }

    private async void OnMessage()
    {
        await WeavyService.SendMessage(UserId);
        await ModalInstance.CloseAsync();
    }

    private async void OnSendProfile()
    {
        var link = $"{NavigationManager.BaseUri}user/{_activeProfileId}";
        var html = $"Please view my <a href=\"{link}\" target=\"_parent\">profile</a>";
        await WeavyService.SendMessage(UserId, html);
        await ModalInstance.CloseAsync();
    }

    private async void OnForwardResume()
    {
        var baseUrl = HttpClientFactory.CreateClient(DefaultHttpClients.Unsecured).BaseAddress!.ToString();
        var link = $"{baseUrl}Document/Resume/{_activeProfileId}";
        var html = $"Please view my <a href=\"{link}\" download>resume</a>";
        await WeavyService.SendMessage(UserId, html);
        await ModalInstance.CloseAsync();
    }

}


