@using ViewModels.Commands
<div class="cpcc-modal">
    <h4 class="section-header">Affinity Group</h4>
    <div class="row my-4">
        <Field Class="col-12 col-sm-6">
            <FieldLabel>Name</FieldLabel>
            <TextEdit Placeholder="Name" @bind-Text="Command.AffinityGroupName"/>
        </Field>
        <Field Class="col-12 col-sm-6">
            <FieldLabel>Website</FieldLabel>
            <TextEdit Placeholder="http://example.com" @bind-Text="Command.AffinityGroupWebsite"/>
        </Field>
        <Field Class="col-12">
            <FieldLabel>Description</FieldLabel>
            <MemoEdit Placeholder="Type here..." @bind-Text="Command.AffinityGroupDescription"/>
        </Field>
    </div>
    <div class="d-flex flex-row-reverse justify-content-between align-items-center mt-2">
        <Button Color="Color.Primary" Size="Size.Large" class="px-4 py-1" @onclick="OnSave">Save</Button>
        <Button Color="Color.Primary" Size="Size.Large" Outline="true" Class="px-4 py-1" @onclick="ModalInstance.CloseAsync">Cancel</Button>
    </div>
</div>

@code {

    [CascadingParameter]
    public BlazoredModalInstance ModalInstance { get; set; }

    [Parameter]
    public UpdateAffinityGroupCommand Command { get; set; }

    private void OnSave()
    {
         ModalInstance.CloseAsync(ModalResult.Ok(Command));
    }

}



