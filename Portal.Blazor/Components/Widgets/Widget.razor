<div class=@($"widget my-2 {Class}")>
    @if (ShowHeader)
    {
        <div class=@(AdditionalAttributes?.ContainsKey("onclick") ?? false ? "widget-header pointer" : "widget-header") @attributes="@AdditionalAttributes">
            <div></div>
            <div class="widget-icon-wrapper">
                <img src="@Icon"/>
            </div>
            <div class="widget-content">
                <div class="widget-title mr-2">
                    @Title
                </div>
                <div class="widget-actions">
                    @Actions
                    @if (ShowCollapse)
                    {
                        <small @onclick="() => _collapsed = !_collapsed">View Details <Icon class="ml-2" Name="@(_collapsed ? IconName.PlusSquare : IconName.MinusSquare)"/></small>
                    }
                </div>
            </div>
        </div>
    }

    @if (!_collapsed)
    {
        @Content
    }
</div>

@code {

    [Parameter]
    public string Class { get; set; }

    [Parameter]
    public RenderFragment Actions { get; set; }

    [Parameter]
    public RenderFragment Content { get; set; }

    [Parameter]
    public bool ShowHeader { get; set; } = true;

    [Parameter]
    public bool ShowCollapse { get; set; } = true;

    [Parameter]
    public string Title { get; set; }

    [Parameter]
    public string Icon { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object> AdditionalAttributes { get; set; }

    [Parameter]
    public bool IsCollapsedOnLoad { get; set; }

    private bool _collapsed;

    protected override void OnInitialized()
    {
        _collapsed = IsCollapsedOnLoad;
        base.OnInitialized();
    }

}

