@using ViewModels.Dtos
@inject MatchingService MatchingService
@inject Blazored.Modal.Services.IModalService ModalService
@inject ToastService ToastService
@inject NavigationManager NavigationManager
<div class="container flex-grow-1 bg-white p-0 match-list">
    @if (_matches.Count == 0)
    {
        if (ActiveProfile.ProfileType == ProfileType.Student)
        {
            <div class="card connect">
                <div class="card-body text-center">
                    <img src="images/looking_circle_matches.svg" alt="" class="circle">
                    <p class="card-text">You Currently Have No Suggested Matches</p>
                    @if (Type is UserConnectionType.Mentoring)
                    {
                        <button @onclick="() => ClickSearchAll(MatchingSection.ViewAll, Mentor)" class="btn btn-primary btn-lg">View All Mentors</button>
                    }
                    else
                    {
                        <button @onclick="() => ClickSearchAll(MatchingSection.ViewAll, Connector)" class="btn btn-primary btn-lg">View All Connectors</button>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="card connect">
                <div class="card-body text-center">
                    <img src="images/looking_circle_matches.svg" alt="" class="circle">
                    <p class="card-text">You Currently Have No Suggested Matches</p>
                    <button @onclick="() => ClickSearchAll(MatchingSection.ViewAll, Student)" class="btn btn-primary btn-lg">View All Students</button>
                </div>
            </div>    
        }
    }
    else
    {
        <ScrollableElement Class="h-100 w-100 overflow-auto position-absolute p-3" OnBottomReachedCallback="OnScroll">
            @foreach (var match in _matches)
            {
                <ListUserCard UserId="match.UserId" @key="match.Id">
                    <div class="d-flex justify-content-end mt-2 mt-md-0">
                        <Button Color="Color.Light" Class="mr-2" @onclick="() => OnConnect(match)"><img src="images/thumbs_up_alt.svg" class="mr-2"/>Connect Now</Button>
                        <Button Color="Color.Secondary" TextColor="TextColor.Body" class="lighten" @onclick="() => OnDecline(match)"><img src="images/thumbs_down.svg" class="mr-2"/>Not Interested</Button>
                    </div>
                </ListUserCard>
            }
        </ScrollableElement>
    }
    
</div>

@code {

    [Parameter]
    public UserConnectionType Type { get; set; }

    [CascadingParameter]
    public FullUserProfileDto ActiveProfile { get; set; }

    private IDisposable _sub;
    private List<PotentialConnectionDto> _matches = new();
    
    [Parameter]
    public EventCallback<(MatchingSection, string)> ShowAllClicked { get; set; }

    protected override void OnParametersSet()
    {
        _sub = (Type switch {
            UserConnectionType.Assisting => MatchingService.ConnectorMatches,
            UserConnectionType.Mentoring => MatchingService.MentorMatches
            }).Subscribe(matches =>
            {
                _matches = matches.GroupBy(x => x.Id).
                       Select(x => x.First()).ToList();
                StateHasChanged();
            });
    }

    private void OnScroll()
    {
        MatchingService.SearchQuery.Skip = _matches.Count;
        MatchingService.GetMatches(true);
    }

    private async void OnConnect(PotentialConnectionDto match)
    {
        try
        {
            await MatchingService.ApproveMatch(match);
            var parameters = new ModalParameters();
            parameters.Add(nameof(ConnectionRequestSentModal.UserId), match.UserId);
            parameters.Add(nameof(ConnectionRequestSentModal.ShowForwardResume), ActiveProfile.Resume != null);
            var modal = ModalService.Show<ConnectionRequestSentModal>("", parameters);
        }
        catch (Exception e)
        {
            ToastService.ShowToast(e.Message, ToastLevel.Error, "Unknown Error");
        }
    }

    private void OnDecline(PotentialConnectionDto match)
    {
        MatchingService.DeclineMatch(match.Id);
    }
    
    private void ClickSearchAll(MatchingSection section, string search)
    {
        ShowAllClicked.InvokeAsync((section, search));
    }

        private const string Mentor = "mentors";
        private const string Connector = "connectors";
        private const string Student = "students";
}


