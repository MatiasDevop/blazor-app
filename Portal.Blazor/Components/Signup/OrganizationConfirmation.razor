        <div class="col">
            <h4 class="section-header">Who We Are</h4>
        </div>
        <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(SignupSection.CareerCenterDetails)">
