}

<div class="row mt-4">
    <div class="col d-flex flex-row">
        <h4 class="section-header mr-4">YouTube Video</h4>
        <div>@Claim.VideoUrl</div>
    </div>
    <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(AccountType == AccountType.Company ? SignupSection.CompanyDetails : SignupSection.CareerCenterDetails)">
        <Icon Name="IconName.Edit"/>
    </Button>
</div>

<div class="row mt-4">
    <div class="col">
        <h4 class="section-header">Social Media</h4>
    </div>
    <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(AccountType is AccountType.Company ? SignupSection.CompanyDetails : SignupSection.CareerCenterDetails)">
        <Icon Name="IconName.Edit"/>
    </Button>
</div>
<div class="row">
    @foreach (var socialLink in Claim.SocialLinks)
    {
        <div class="col-5 my-2">
            <div class="input-group">
                <div class="input-group-prepend social-media" id="@_socialMedia[socialLink.Type].Label.ToLower()">
                    <img src="images/@(_socialMedia[socialLink.Type].Label.ToLower()).svg"/>
                </div>
                <TextEdit Text="@socialLink.Url" Disabled="true"/>
            </div>
        </div>
    }
</div>

@if (AccountType == AccountType.Company)
{
    <div class="row mt-4">
        <div class="col">
            <h4 class="section-header">Affinity Group</h4>
        </div>
        <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(SignupSection.CorporateDocuments)">
            <Icon Name="IconName.Edit"/>
        </Button>
    </div>
    <div class="row">
        <div class="col-12 col-sm-6 d-flex d-sm-block flex-row justify-content-between">
            <label>Name</label>
            <div>@CompanyClaim.AffinityGroupName</div>
        </div>
        <div class="col-12 col-sm-6 d-flex d-sm-block flex-row justify-content-between">
            <label>Website</label>
            <div>@CompanyClaim.AffinityGroupWebsite</div>
        </div>
        <div class="col-12 d-flex d-sm-block flex-row justify-content-between">
            <label>Description</label>
            <div>@CompanyClaim.AffinityGroupDescription</div>
        </div>
    </div>

    @if (CommitmentDocument != null)
    {
        <div class="row">
            <ChildWidget Title="Diversity & Inclusion Commitment" Class="col-12 pr-0">
                @if (!string.IsNullOrEmpty(CommitmentDocument.Url))
                {
                    <span>
                        <b>URL:&nbsp;</b><a href="@CommitmentDocument.Url" target="_blank">@CommitmentDocument.Url</a>
                    </span>
                }
                <div>
                    @CommitmentDocument.Description
                </div>
                @if (CommitmentDocument.File != null)
                {
                    <div class="col-12 d-flex flex-row">
                        <img src="images/pdf.svg"/>
                        <div class="ml-2">
                            <div>
                                @CommitmentDocument.File.FileName
                            </div>
                        </div>
                    </div>
                }
            </ChildWidget>
        </div>
    }
    @if (SocialJusticeDocument != null)
    {
        <div class="row">
            <ChildWidget Title="Highlights of Social Justice & Equity Policy & Practice" Class="col-12 pr-0">
                @if (!string.IsNullOrEmpty(SocialJusticeDocument.Url))
                {
                    <span>
                        <b>URL:&nbsp;</b><a href="@SocialJusticeDocument.Url" target="_blank">@SocialJusticeDocument.Url</a>
                    </span>
                }
                <div>
                    @SocialJusticeDocument.Description
                </div>
                @if (SocialJusticeDocument.File != null)
                {
                    <div class="col-12 d-flex flex-row">
                        <img src="images/pdf.svg"/>
                        <div class="ml-2">
                            <div>
                                @SocialJusticeDocument.File.FileName
                            </div>
                        </div>
                    </div>
                }
            </ChildWidget>
        </div>
    }
    @if (InclusionDocument != null)
    {
        <div class="row">
            <ChildWidget Title="Highlights of LGBTQ Inclusion Policy & Practices" Class="col-12 pr-0">
                @if (!string.IsNullOrEmpty(InclusionDocument.Url))
                {
                    <span>
                        <b>URL:&nbsp;</b><a href="@InclusionDocument.Url" target="_blank">@InclusionDocument.Url</a>
                    </span>
                }
                <div>
                    @InclusionDocument.Description
                </div>
                @if (InclusionDocument.File != null)
                {
                    <div class="col-12 d-flex flex-row">
                        <img src="images/pdf.svg"/>
                        <div class="ml-2">
                            <div>
                                @InclusionDocument.File.FileName
                            </div>
                        </div>
                    </div>
                }
            </ChildWidget>
        </div>
    }

    <div class="row mt-4">
        <div class="col d-flex flex-row">
            <h4 class="section-header mr-4">Work Authorizations Accepted By Your Company</h4>
            @if (true)
            {
                ListAccepted = null;
            }
            @foreach (var item in CompanyClaim.AcceptedWorkAuthorizations)
            {
                switch (item.WorkAuthorization)
                {
                    case WorkAuthorizationType.Other:
                        ListAccepted += " " + @CompanyClaim.WorkAuthorizationOther + ",";
                        break;
                    case WorkAuthorizationType.F1Visa:
                        ListAccepted += " Student Visa,";
                        break;
                    case WorkAuthorizationType.J1Visa:
                        ListAccepted += " Exchange Program,";
                        break;
                    case WorkAuthorizationType.UsCitizen:
                        ListAccepted += " US Citizen,";
                        break;
                    case WorkAuthorizationType.H1BVisa:
                        ListAccepted += " Professional Work Visa,";
                        break;
                }
            }
            @if (ListAccepted != null)
            {
                int index = ListAccepted.LastIndexOf(',');
                <div class="m-1">@ListAccepted.Remove(index, 1)</div>
            }
        </div>
        <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(SignupSection.WorkAuthorization)">
            <Icon Name="IconName.Edit"/>
        </Button>
    </div>
}

