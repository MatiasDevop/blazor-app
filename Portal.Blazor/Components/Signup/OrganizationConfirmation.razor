@using ViewModels.Commands
@using Constants
@using Microsoft.Extensions.Logging
@using Portal.Blazor.Extensions
@using ViewModels.Dtos

@inject SmartTypesService SmartTypesService
@inject Blazored.Modal.Services.IModalService ModalService
@inject PartnerPlanService PartnerPlanService
@inject ILogger<OrganizationConfirmation> Logger

<div class="signup-confirmation container">
<h3 class="section-header">Please Check The Information Below</h3>
@if (!Transitioning)
{
    <div class="row mt-4">
        <div class="col">
            <h4 class="section-header">Business Admin Information</h4>
        </div>
        <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(SignupSection.AboutYou)">
            <Icon Name="IconName.Edit"/>
        </Button>
    </div>
    <div class="d-flex flex-row flex-wrap justify-content-center">
        <div class="profile-img-wrapper">
            <img src="@(ProfileImageData)" class="w-100"/>
        </div>
        <div class="col-12 col-sm d-flex flex-row flex-wrap p-0">
            <div class="col-6 col-sm-4 mb-2">
                <label>Full Name</label>
                <div>@Command.FirstName @Command.LastName</div>
            </div>
            <div class="col-6 col-sm-8 mb-2">
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Email</label>
                <div>@Command.EmailAddress</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Phone</label>
                <div>
                    @Command.Phone
                    @if (Command.PhoneKeepPrivate)
                    {
                        <span> (private)</span>
                    }
                </div>
            </div>
        </div>
    </div>
}
<div class="row mt-4">
    <div class="col">
        <h4 class="section-header">About Your @(AccountType == AccountType.Company ? "Company" : "Career Center")</h4>
    </div>
    <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(AccountType == AccountType.Company ? SignupSection.CompanyDetails : SignupSection.CareerCenterDetails)">
        <Icon Name="IconName.Edit"/>
    </Button>
</div>
<div class="d-flex flex-row flex-wrap justify-content-center">
    <div class="profile-img-wrapper">
        <img src="@(OrganizationImageData)" alt="Organization Image" class="w-100"/>
    </div>
    <div class="col-12 col-sm d-flex flex-row flex-wrap p-0">
        @if (AccountType == AccountType.Company)
        {
            <div class="col-6 col-sm-4 mb-2">
                <label>Company Name</label>
                <div>@CompanyClaim.Company.Name</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Company Website</label>
                <div>@Claim.Website</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Company Size</label>
                <div>@OrganizationSize</div>
            </div>
            <div class="col-4 mb-2">
                <label>Email</label>
                <div>@Claim.Email</div>
            </div>
            <div class="col-8 mb-2 word-break-all">
                <label>Description</label>
                <div>@Claim.Description</div>
            </div>
        }
        else if (AccountType == AccountType.CareerCenter)
        {
            <div class="col-6 col-sm-4 mb-2">
                <label>College / University</label>
                <div>@SchoolClaim.School.DisplayName</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Email Address</label>
                <div>@SchoolClaim.Email</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Institution Type</label>
                <div>@InstitutionType.Label</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Company Name</label>
                <div>@SchoolClaim.CareerCenterName</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>College / University Size</label>
                <div>@OrganizationSize</div>
            </div>
            <div class="col-6 col-sm-4 mb-2">
                <label>Career Center Website</label>
                <div>@Claim.Website</div>
            </div>
        }
    </div>
</div>

<div class="row mt-4">
    <div class="col">
        <h4 class="section-header">@(AccountType == AccountType.Company ? "Company" : "Career Center") Address</h4>
    </div>
    <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(AccountType == AccountType.Company ? SignupSection.CompanyDetails : SignupSection.CareerCenterDetails)">
        <Icon Name="IconName.Edit"/>
    </Button>
</div>
<div class="row">
    <div class="col-12 col-sm-4 d-flex d-sm-block flex-row justify-content-between">
        <label>Address</label>
        <div>@Claim.Address.Line1</div>
    </div>
    <div class="col-12 col-sm-4 d-flex d-sm-block flex-row justify-content-between">
        <label>City</label>
        <div>@Claim.Address.City</div>
    </div>
    @if (!IsInternational)
    {
        <div class="col-12 col-sm-4 d-flex d-sm-block flex-row justify-content-between">
            <label>State</label>
            <div>@State</div>
        </div>
        <div class="col-12 col-sm-4 d-flex d-sm-block flex-row justify-content-between">
            <label>Zip Code</label>
            <div>@Claim.Address.ZipCode</div>
        </div>
    }
    <div class="col-12 col-sm-4 d-flex d-sm-block flex-row justify-content-between">
        <label>Country</label>
        <div>@Country</div>
    </div>
    <div class="col-12 col-sm-4 d-flex d-sm-block flex-row justify-content-between">
        <label>Region</label>
        <div>@Region</div>
    </div>
</div>

@if (AccountType == AccountType.CareerCenter)
{
