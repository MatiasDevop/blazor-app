<div class="row mt-4">
    <div class="col">
        <h4 class="section-header">Your Selected Partnership Level</h4>
    </div>
    <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(SignupSection.PlanSelection)">
        <Icon Name="IconName.Edit"/>
    </Button>
</div>
<div class="row mt-4">
    <div class="col-12 my-2">
        <PartnerPlanLineItem PartnerPlan="ActivePlan"/>
    </div>
</div>

<div class="row mt-4">
    <div class="col">
        <h4 class="section-header">Applied Discounts</h4>
    </div>
    <Button Color="Color.Primary" Outline="true" Class="edit-btn" @onclick="() => OnNavigate.InvokeAsync(SignupSection.PlanSelection)">
        <Icon Name="IconName.Edit"/>
    </Button>
</div>
<div class="row flex-row mt-4 discount-summary align-items-center">
    <i class="fa fa-2x fa-check col-1"/>
    @if (Claim.Discount?.Id != Guid.Empty)
    {
        <h4 class="col-3 m-0">@Claim.Discount.Code</h4>
        <h4 class="col-4 m-0">@Claim.Discount.Description</h4>
        <h4 class="col-4 m-0 d-flex justify-content-end">@Claim.Discount.ApplyDiscount(ActivePlan.CurrentPrice.SalePrice ?? ActivePlan.CurrentPrice.BasePrice).ToString("C")</h4>
    }
    else
    {
        <h4 class="col-8 m-0">No Discounts Applied</h4>
        <h4 class="col-3 m-0 d-flex justify-content-end">$0.00</h4>
    }
</div>

<div class="my-2 d-flex justify-content-end align-items-baseline" id="total">
    <h4 class="pr-1">Total: </h4>
    <h4 class="m-0 mr-4 pr-1">@GetTotal().ToString("C")</h4>
</div>

<div class="flex-1"></div>
<div class="d-flex flex-row align-items-center justify-content-between">
    <Button TextColor="TextColor.Primary" @onclick="OnPrev" Class="px-4 py-1"> <i class="fas fa-arrow-left mr-2"></i> Previous Step</Button>
    <Button Color="Color.Primary" TextColor="TextColor.White" @onclick="HandleNext" Class="px-5 py-1" Disabled="@_loading">
        @if (_loading)
        {
            <div class="spinner-border mr-2" role="status">
                <span class="sr-only">Loading...</span>
            </div>
        }
        Next <i class="fas fa-arrow-right ml-2"></i>
    </Button>
</div>
</div>

@code
{
        private const string DefaultProfileIcon = "images/company_profile_default.svg";

    private static readonly Dictionary<string, string> MultiSelectionHeaders = new()
    {
        {CompanyMultiselectFields.JobIndustry, "Company Job Industry"},
        {CompanyMultiselectFields.CandidateJobIndustry, "Types of Career Candidates Looking For"}
    };

    [CascadingParameter]
    public AccountType AccountType { get; set; }

    [Parameter]
    public RegisterOrganizationCommand Command { get; set; }

    [Parameter]
    public EventCallback OnPrev { get; set; }

    [Parameter]
    public EventCallback OnNext { get; set; }

    [Parameter]
    public EventCallback<SignupSection> OnNavigate { get; set; }

    [Parameter]
    public bool Transitioning { get; set; }

    private string ListAccepted { get; set; }

    private bool _loading = false;
    private List<SmartCodeDto> _organizationSizes = new();
    private List<SmartCodeDto> _states = new();
    private List<SmartCodeDto> _countries = new();
    private List<SmartCodeDto> _regions = new();
    private List<SmartCodeDto> _schoolSizes = new();
    private List<SmartCodeDto> _institutionTypes = new();
    private List<PartnerPlanDto> _partnerPlans = new();
    private Dictionary<Guid, SmartCodeDto> _socialMedia = new();

    private string OrganizationImageData => AccountType switch 
    {
        AccountType.Company => Claim.Logo?.ToDataString() ?? DefaultProfileIcon,
        AccountType.CareerCenter => Claim.Logo?.ToDataString() ?? DefaultProfileIcon,
        };

    private string ProfileImageData => Command.ProfileImage == null
        ? DefaultProfileIcon
        : Command.ProfileImage.ToDataString();

    private BaseOrganizationClaimDto Claim => AccountType switch
    {
        AccountType.Company => (Command as RegisterCompanyCommand).Claim,
        AccountType.CareerCenter => (Command as RegisterCareerCenterCommand).Claim
        };

    private CompanyClaimDto CompanyClaim => Claim as CompanyClaimDto;
    private SchoolClaimDto SchoolClaim => Claim as SchoolClaimDto;

    private string OrganizationUnit => AccountType switch 
    {
        AccountType.Company => "Employees",
        AccountType.CareerCenter => "Students"
        };

    private SmartCodeDto Size => AccountType switch 
    {
        AccountType.Company => _organizationSizes.FirstOrDefault(x => x.Id == Claim.OrganizationSize),
        AccountType.CareerCenter => _schoolSizes.FirstOrDefault(x => x.Id == Claim.OrganizationSize),
        };

    private PartnerPlanDto ActivePlan => _partnerPlans.FirstOrDefault(x => x.Id == Claim?.PartnerPlan);
    private SmartCodeDto InstitutionType => _institutionTypes.FirstOrDefault(x => x.Id == SchoolClaim.InstitutionType);
    private CompanyDocumentDto CommitmentDocument => CompanyClaim.Documents[CompanyDocumentType.Commitment];
    private CompanyDocumentDto InclusionDocument => CompanyClaim.Documents[CompanyDocumentType.Inclusion];
    private CompanyDocumentDto SocialJusticeDocument => CompanyClaim.Documents[CompanyDocumentType.SocialJustice];
    private CareerCenterDocumentDto StudentOfferingsDocument => SchoolClaim.Documents[CareerCenterDocumentType.StudentOfferings];
    private CareerCenterDocumentDto DiversityDocument => SchoolClaim.Documents[CareerCenterDocumentType.DiversityAndInclusionCommitment];

    private string OrganizationSize => $"{Size.Label} {OrganizationUnit}";
    private string State => _states.FirstOrDefault(x => x.Id == Claim.Address.State)?.Label;
    private string Country => _countries.FirstOrDefault(x => x.Id == Claim.Address.Country)?.Label;
    private string Region => _regions.FirstOrDefault(x => x.Id == Claim.Address.Region)?.Label;
    private bool IsInternational => Claim.Address.Region == (_regions?.FirstOrDefault(x => x.Code == "INT")?.Id ?? Guid.NewGuid());

    protected override void OnInitialized()
    {
        SmartTypesService[SmartTypes.OrganizationSize].Subscribe(smartCodes =>
        {
            _organizationSizes = smartCodes;
            StateHasChanged();
        });
        SmartTypesService[SmartTypes.State].Subscribe(smartCodes =>
        {
            _states = smartCodes;
            StateHasChanged();
        });
        SmartTypesService[SmartTypes.Country].Subscribe(smartCodes =>
        {
            _countries = smartCodes;
            StateHasChanged();
        });
        SmartTypesService[SmartTypes.SocialMedia].Subscribe(smartCodes =>
        {
            _socialMedia = smartCodes.ToDictionary(x => x.Id);
            StateHasChanged();
        });
        SmartTypesService[SmartTypes.Region].Subscribe(smartCodes =>
        {
            _regions = smartCodes;
            StateHasChanged();
        });
        SmartTypesService[SmartTypes.SchoolSize].Subscribe(smartCodes =>
        {
            _schoolSizes = smartCodes;
            StateHasChanged();
        });
        SmartTypesService[SmartTypes.InstitutionType].Subscribe(smartCodes =>
        {
            _institutionTypes = smartCodes;
            StateHasChanged();
        });
        var requestId = Guid.NewGuid();
        Logger.LogInformation($"Discount Id: {Claim.Discount.Id} : {requestId}");

        var planType = AccountType switch {
            AccountType.Company => PlanType.Company,
            AccountType.CareerCenter => PlanType.CareerCenter
            };

        PartnerPlanService[planType].Subscribe(partnerPlans =>
        {
            var requestId = Guid.NewGuid();
            var nullString = _partnerPlans == null ? string.Empty : "not ";
            Logger.LogInformation($"Pre-Load: _partnerPlans is {nullString}null : RequestId - {requestId}");
            _partnerPlans = partnerPlans?.Where(x => x.CurrentPrice != null).OrderBy(x => x.DisplayOrder).ToList();
            nullString = _partnerPlans == null ? string.Empty : "not ";
            Logger.LogInformation($"Post-Load: _partnerPlans is {nullString}null : RequestId - {requestId}");
            Logger.LogInformation($"_partnerPlans count is {_partnerPlans?.Count.ToString() ?? "null"} : RequestId - {requestId}");
            StateHasChanged();
        });
    }

    private decimal GetTotal()
    {
        var price = ActivePlan == null ? 0 : ActivePlan.CurrentPrice.SalePrice ?? ActivePlan.CurrentPrice.BasePrice;
        var discount = Claim.Discount;
        return discount?.ApplyDiscount(price) ?? price;
    }

    private void HandleNext()
    {
        _loading = true;
        StateHasChanged();
        OnNext.InvokeAsync();
    }
}

