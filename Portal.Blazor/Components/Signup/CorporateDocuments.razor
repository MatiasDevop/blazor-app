@using Microsoft.AspNetCore.Components
@using ViewModels.Commands
@using global::Enums
@using System.Text.Json
<div class="corporate-documents">
    <h4 class="section-header">Affinity Group</h4>
    <div class="row my-4">
        <Field Class="col-12 col-sm-6">
            <FieldLabel>Name</FieldLabel>
            <TextEdit Placeholder="Name" @bind-Text="Command.Claim.AffinityGroupName"/>
        </Field>
        <Field Class="col-12 col-sm-6">
            <FieldLabel>Website</FieldLabel>
            <TextEdit Placeholder="http://example.com" @bind-Text="Command.Claim.AffinityGroupWebsite"/>
        </Field>
        <Field Class="col-12">
            <FieldLabel>Description</FieldLabel>
            <MemoEdit Placeholder="Type here..." @bind-Text="Command.Claim.AffinityGroupDescription"/>
        </Field>
    </div>

    <h4 class="section-header">Diversity & Inclusion Commitment</h4>
    <div class="my-4">
        <OrganizationDocumentForm Document="Command.Claim.Documents[CompanyDocumentType.Commitment]"/>
    </div>

    <h4 class="section-header">Highlights of Social Justice & Equity Policy & Practice</h4>
    <div class="my-4">
        <OrganizationDocumentForm Document="Command.Claim.Documents[CompanyDocumentType.SocialJustice]"/>
    </div>

    <h4 class="section-header">Highlights of LGBTQ Inclusion Policy & Practice</h4>
    <div class="my-4">
        <OrganizationDocumentForm Document="Command.Claim.Documents[CompanyDocumentType.Inclusion]"/>
    </div>

    <div class="flex-1"></div>
    <div class="d-flex flex-row align-items-center justify-content-between">
        <Button TextColor="TextColor.Primary" @onclick="OnPrev" Class="px-4 py-1"> <i class="fas fa-arrow-left mr-2"></i> Previous Step</Button>
        <Button Color="Color.Primary" TextColor="TextColor.White" @onclick="HandleNext" Class="px-4 py-1">Next <i class="fas fa-arrow-right ml-2"></i></Button>
    </div>
</div>

@code {

    [CascadingParameter]
    public AccountType AccountType { get; set; }

    [Parameter]
    public RegisterCompanyCommand Command { get; set; }

    [Parameter]
    public EventCallback OnPrev { get; set; }

    [Parameter]
    public EventCallback OnNext { get; set; }

    private void HandleNext()
    {
        Console.WriteLine("Before Next");
        Console.WriteLine(JsonSerializer.Serialize(Command.Claim.Documents));
        OnNext.InvokeAsync();
    }

}

