@using ViewModels.Dtos
@using ViewModels.Commands
@using JsonSerializer = Newtonsoft.Json.JsonSerializer
@inject Blazored.Modal.Services.IModalService ModalService
<div class="education-details">
    <h4 class="section-header">My Educational Details</h4>
    <EducationHistoryForm @ref="_educationHistoryForm" EducationHistory="_educationHistory" AccountType="AccountType" Class="mt-4 mb-2" StatusChanged="args => _valid = args.Status"/>

    <div class="d-flex flex-row-reverse mb-2">
        <Button Color="Color.Primary" @onclick="AddEducationHistory" Class="px-4 py-1">Add</Button>
        <Button Color="Color.Primary" Outline="true" @onclick="Cancel" Class="mx-2 px-4 py-1">Cancel</Button>
    </div>

    @foreach (var (educationHistory, i) in Command.EducationHistories.Select((x, i) => (x,i)))
    {
        <EducationHistoryCard EducationHistory="educationHistory" OnEdit="x => OnEdit(x, i)" OnDelete="OnDelete"/>
    }
    <div class="flex-1 mt-4 d-flex justify-content-center">
        @if (_canContinue != null && _canContinue == false)
        {
            <span class="text-danger">You must add a minimum of one educational record to continue.</span>
        }
    </div>
    <div class="d-flex flex-row align-items-center justify-content-between">
        <Button TextColor="TextColor.Primary" @onclick="OnPrev" Class="px-4 py-1"> <i class="fas fa-arrow-left mr-2"></i> Previous Step</Button>
        <Button Color="Color.Primary" TextColor="TextColor.White" @onclick="HandleNext" Class="px-4 py-1">Next <i class="fas fa-arrow-right ml-2"></i></Button>
    </div>
</div>

@code {
    private EducationHistoryDto _educationHistory = new();
    private EducationHistoryForm _educationHistoryForm;
    private ValidationStatus _valid = ValidationStatus.None;
    private bool? _canContinue;

    [Parameter]
    public RegisterIndividualCommand Command { get; set; }

    [Parameter]
    public EventCallback OnNext { get; set; }

    [Parameter]
    public EventCallback OnPrev { get; set; }

    [CascadingParameter]
    public AccountType AccountType { get; set; }

    private async void AddEducationHistory()
    {
        if (!await _educationHistoryForm.Validate())
            return;
        if (_valid != ValidationStatus.Success)
            return;
        
        Command.EducationHistories.Add(_educationHistory);
        _educationHistory = new();
        _educationHistoryForm.Reset();
    }

    private void Cancel()
    {
        _educationHistory = new();
        _educationHistoryForm.Reset();
    }

    private void HandleNext()
    {
        if (AccountType is AccountType.Student)
        {
            _canContinue = Command.EducationHistories.Any();
            if (_canContinue == false)
                return;
        }
        OnNext.InvokeAsync();
    }

    private async void OnEdit(EducationHistoryDto educationHistory, int index)
    {
        var parameters = new ModalParameters();
        var clone = (EducationHistoryDto)educationHistory.Clone();
        parameters.Add("EducationHistory", clone);
        parameters.Add("AccountType", AccountType);
        var modal = ModalService.Show<EditEducationHistoryModal>("", parameters);
        var result = await modal.Result;
        if (result.Cancelled)
            return;
        Command.EducationHistories[index] = clone;
        StateHasChanged();
    }

    private async void OnDelete(EducationHistoryDto educationHistory)
    {
        var parameters = new ModalParameters();
        parameters.Add("EducationHistory", educationHistory);
        var modal = ModalService.Show<DeleteEducationHistoryModal>("", parameters);
        var result = await modal.Result;
        if (result.Cancelled)
            return;
        Command.EducationHistories.Remove(educationHistory);
        StateHasChanged();
    }

}

