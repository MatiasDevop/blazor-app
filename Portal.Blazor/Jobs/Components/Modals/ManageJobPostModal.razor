@using ViewModels.Dtos

<div class="card py-3 px-3">
    <div class="row">
        <div class="col-5" style="padding-right: 0;">
            <Button Color="Color.Primary" @onclick="ViewAllJobs">View All Jobs</Button>
        </div>
        <div class="col" style="margin-top: 10px;padding: 0;">Or</div>
        <div class="col-6" style="width: 20em;left: 15px;padding-left: 0;">
            <Button Color="Color.Primary" @onclick="ManageCompanyJobs" style="width: max-content;">Manage Company Jobs</Button>
        </div>
    </div>
</div>

@code {
    
    [Parameter]
    public FullUserProfileDto UserProfile { get; set; }
    
    [Parameter]
    public bool IsJobManager { get; set; }
    
    [CascadingParameter]
    BlazoredModalInstance ModalInstance { get; set; }

    private async void ViewAllJobs()
    {
        IsJobManager = false;
        if (UserProfile.Id == Guid.Empty)
            return;
        await ModalInstance.CloseAsync(ModalResult.Ok(IsJobManager));
    }

    private async void ManageCompanyJobs()
    {
        IsJobManager = true;
        if (UserProfile.Id == Guid.Empty)
            return;
        await ModalInstance.CloseAsync(ModalResult.Ok(IsJobManager));
    }
}



