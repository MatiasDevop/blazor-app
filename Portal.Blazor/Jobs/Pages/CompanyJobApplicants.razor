@page "/jobs/company/applicants/{Id:guid}"
@using ViewModels.Dtos
@using Portal.Blazor.Jobs.Services
@using System.Reactive.Linq
@inject JobApplicationService JobApplicationService
@inject JobPostService JobPostService

@layout AuthorizedPageLayout

@attribute [Authorize]

<div style="background-color:#f0f4f6; height:100%">
    @if (JobPost != null)
    {
        <div class="container px-5 mt-2">
            <CompanyJobCard JobPost="JobPost" OverrideCPCC="true" ShowEditButtons="true"> </CompanyJobCard>
        </div>

        <div class="detail-page matching">
            <div class="container px-5 mt-2">

                @if (JobPost.UseCpccApply)
                {
                    <div class="matching-nav row" style="padding: 0 20px;">
                        <div class="col-md-3" style="padding: 0; justify-content: left;">
                            <h4 class="section-header">Applicants</h4>
                        </div>
                        <div class="col-md-2 pointer @(CurrentTab is JobApplicationStatus.NotTracked ? "active" : "")" @onclick="() => ChangeTab(JobApplicationStatus.NotTracked)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20">
                                <g transform="translate(0 0)">
                                    <g>
                                        <path d="M3.556.61A2.083,2.083,0,1,1,.61.61,2.083,2.083,0,0,1,3.556.61Z" transform="translate(7.917 8.542)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                        <path d="M3.556.61A2.083,2.083,0,1,1,.61.61,2.083,2.083,0,0,1,3.556.61Z" transform="translate(12.488 3.542)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                        <path d="M0,0A5.459,5.459,0,0,1,3.333,1.111" transform="translate(15 10.208)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                        <path d="M3.556.61A2.083,2.083,0,1,1,.61.61,2.083,2.083,0,0,1,3.556.61Z" transform="translate(3.345 3.542)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                        <path d="M0,1.111A5.459,5.459,0,0,1,3.333,0" transform="translate(1.667 10.208)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                        <path d="M7.652,1.25A6.389,6.389,0,0,0,3.826,0,6.389,6.389,0,0,0,0,1.25" transform="translate(6.174 15.208)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                    </g>
                                    <path d="M0,0H20V20H0Z" transform="translate(0 0)" fill="none"/>
                                </g>
                            </svg>
                            For Review
                        </div>

                        <div class="col-md-2 pointer @(CurrentTab is JobApplicationStatus.GoodFit ? "active" : "")" @onclick="() => ChangeTab(JobApplicationStatus.GoodFit)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 40 40">
                                <g clip-path="url(#clip-path)" transform="translate(20906 11657)" id="Mask_Group_52">
                                    <g id="user-checkmark" transform="translate(-20906.25 -11657)">
                                        <path id="Path_25637" d="M18.36,3H8.76A5.76,5.76,0,0,0,3,8.76v5.76" transform="translate(0.69 0)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"></path>
                                        <path id="Path_25638" d="M17,28.36h1.92a5.76,5.76,0,0,0,5.76-5.76V13" transform="translate(13.57 9.2)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="3"></path>
                                        <circle id="Ellipse_446" cx="7.68" cy="7.68" r="7.68" transform="translate(22.89 3)" fill="currentColor"></circle>
                                        <path id="Path_25639" d="M20.55,6.5l-3,2.88-1.8-1.728" transform="translate(12.42 3.22)" fill="none" stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"></path>
                                        <circle id="Ellipse_447" cx="4.8" cy="4.8" r="4.8" transform="translate(8.49 18.36)" fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1"></circle>
                                        <path id="Path_25640" d="M22.2,23.3a4.8,4.8,0,0,0-4.8-4.8H7.8A4.8,4.8,0,0,0,3,23.3" transform="translate(0.69 14.26)" fill="currentColor" fill-rule="evenodd"></path>
                                        <path id="Path_25641" d="M24.33,23.99a6.24,6.24,0,0,0-6.24-6.24v2.88a3.36,3.36,0,0,1,3.36,3.36Zm-6.24-6.24H8.49v2.88h9.6Zm-9.6,0a6.24,6.24,0,0,0-6.24,6.24H5.13a3.36,3.36,0,0,1,3.36-3.36Z" transform="translate(0 13.57)" fill="currentColor"></path>
                                    </g>
                                </g>
                            </svg>
                            Interested
                        </div>

                        <div class="col-md-2 pointer @(CurrentTab is JobApplicationStatus.NotAFit ? "active" : "")" @onclick="() => ChangeTab(JobApplicationStatus.NotAFit)">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20">
                                <g transform="translate(0 0)">
                                    <path d="M5.833,0h-2.5A3.333,3.333,0,0,0,0,3.333v.833" transform="translate(2.5 12.5)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                    <circle cx="3.333" cy="3.333" r="3.333" transform="translate(5.833 2.5)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                    <path d="M0,0H20V20H0Z" transform="translate(0 0)" fill="none"/>
                                    <circle cx="3.542" cy="3.542" r="3.542" transform="translate(10.417 11.25)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                    <path d="M0,0V1.38l1.088.664" transform="translate(13.874 13.598)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                </g>
                            </svg>
                            Not Interested
                        </div>

                        <div class="col-md-3"></div>
                    </div>

                    @if (JobApplications != null)
                    {
                        foreach (var jobApplication in JobApplications)
                        {
                            if (CurrentTab == jobApplication.Status)
                            {
                                <ApplicantJobCard JobApplication="jobApplication"></ApplicantJobCard>
                            }
                        }
                    }
                }
                else
                {
                    <div class="matching-nav">
                        <div class="col-sm" style="padding: 0; justify-content: left;">
                            <h4 class="section-header">Applicants Forwarded to Apply with the External Company</h4>
                        </div>

                        <div class="col-sm"></div>
                        <div class="col-sm"></div>
                        <div class="col-sm"></div>
                        <div class="col-sm"></div>
                    </div>


                    @if (JobApplications != null)
                    {
                        foreach (var jobApplication in JobApplications)
                        {
                            <ApplicantJobCard JobApplication="jobApplication"></ApplicantJobCard>
                        }
                    }
                }
            </div>
        </div>
    }

</div>


@code {

    [Parameter]
    public Guid Id { get; set; }

    private JobPostDto JobPost { get; set; }
    private List<JobApplicationDto> JobApplications { get; set; }
    private JobApplicationStatus CurrentTab { get; set; } = JobApplicationStatus.NotTracked;

    private void ChangeTab(JobApplicationStatus jobApplicationStatus)
    {
        CurrentTab = jobApplicationStatus;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        await JobPostService.GetJobPost(Id,true);

        JobPostService.CurrentJobPost.Where(i => i != null).Subscribe(async i =>
        {
            JobPost = i;
            await JobApplicationService.GetJobApplicationsForJobPost(JobPost.Id);
            StateHasChanged();
        });

        JobApplicationService.JobApplicationsForJobPost.Subscribe(i =>
        {
            JobApplications = i;
            StateHasChanged();
        });

        await base.OnInitializedAsync();
    }

}



