@using ViewModels.Dtos
@inherits LayoutComponentBase
@inject UserProfileService UserProfileService
@inject WeavyService WeavyService
@inject ILogger<AuthorizedPageLayout> _logger

<CascadingValue Value="WeavyService">
    <PopupChat/>
    <div class="page">
        <NavBarAuthorized HideNavigationButtons="true" HideSearchBar="true"/>
        <div class="content">
            @Body
        </div>
    </div>
</CascadingValue>

@code{
    
    [CascadingParameter]
    public FullUserProfileDto ActiveProfile { get; set; }

    private string logKey => ActiveProfile == null ? "anonymous" : ActiveProfile.EmailAddress;

    protected override void OnInitialized()
    {
        base.OnInitialized();
        _logger.LogInformation($"[{logKey}] - Layout Successfully Initialized");
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        _logger.LogInformation($"[{logKey}] - Layout Successfully Rendered");
    }

}

